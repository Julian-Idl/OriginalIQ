NODE_ENV=development

# Backend
BACKEND_PORT=4000
BACKEND_PUBLIC_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
ML_SERVICE_URL=http://localhost:8000
UPLOAD_DIR=uploads

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plagiarism_detector

# ML service
ML_SERVICE_PORT=8000
SERPAPI_API_KEY=
HF_HOME=models/huggingface
SENTENCE_MODEL=sentence-transformers/all-mpnet-base-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
AI_CLASSIFIER_MODEL=models/roberta-ai-detector
ENSEMBLE_MODEL_PATH=models/ensemble.joblib
FAISS_INDEX_PATH=storage/faiss.index
FAISS_METADATA_PATH=storage/faiss_metadata.jsonl
EMBEDDING_CACHE_PATH=storage/embedding_cache.sqlite
SPACY_MODEL=en_core_web_sm
ML_DEVICE=cuda
HF_HUB_OFFLINE=false
TRANSFORMERS_OFFLINE=false
INFERENCE_FP16=true
AI_BATCH_SIZE=8
EMBEDDING_BATCH_SIZE=32
CROSS_ENCODER_BATCH_SIZE=16
MAX_WEB_RESULTS=3
MAX_WEB_SEARCH_CHUNKS=6
WEB_SEARCH_CONCURRENCY=3
WEB_TIMEOUT_SECONDS=12
